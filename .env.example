# Core Identity
AGENT_NAME=blacki

# Model Configuration
# Use provider/model-name for OpenRouter (e.g., openrouter/google/gemini-2.0-flash-001)
ROOT_AGENT_MODEL=openrouter/openai/gpt-oss-120b

# API Keys
OPENROUTER_API_KEY=your-openrouter-key-here

# ---------------------------------------------------------------------------
# Brave Search Tool (optional)
# Model-agnostic alternative to Google Search that works with any LLM.
# Get a free API key at: https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# ---------------------------------------------------------------------------
# Browser Use Cloud (optional browser automation for the agent)
# ---------------------------------------------------------------------------
# Natural-language web automation (scraping, forms, navigation). Get a key at:
# https://cloud.browser-use.com — documented API: https://docs.browser-use.com/cloud/
# BROWSER_USE_API_KEY=bu_your_key_here

# Database Configuration
# asyncpg requires ssl=require instead of sslmode=require
DATABASE_URL=postgresql://user:pass@host:port/dbname?ssl=require
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=1800
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Server Configuration
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080

# Feature Flags
SERVE_WEB_INTERFACE=true
RELOAD_AGENTS=true
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=false

# ---------------------------------------------------------------------------
# Telegram Bot Configuration
# ---------------------------------------------------------------------------
# Enable the Telegram bot integration
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# Post a short "using tool" message in the chat (Telegram turns only; opt-in)
TELEGRAM_TOOL_NOTIFICATIONS=false

# To get a Telegram bot token:
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot and follow the instructions
# 3. Copy the token you receive
# See docs/telegram-setup.md for detailed instructions

# ---------------------------------------------------------------------------
# Observability Configuration (Choose One)
# ---------------------------------------------------------------------------

# Option 1: Langfuse (Recommended)
# Setting these automatically configures OTEL_EXPORTER_OTLP_* for Langfuse.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Option 2: Generic OpenTelemetry (Jaeger, Honeycomb, etc.)
# Use this if you are NOT using Langfuse.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic ...

# ---------------------------------------------------------------------------
# Mem0 Memory Integration (Optional)
# ---------------------------------------------------------------------------
# Enable persistent memory across conversations using mem0ai.
# Self-hosted by default - no mem0 platform API key or separate Qdrant
# service required for local development.
#
# Quick Start:
#   Just set OPENROUTER_API_KEY above - mem0 will work automatically with:
#   - Embedded on-disk Qdrant (data stored in ./data/qdrant)
#   - Local FastEmbed embeddings (model: BAAI/bge-small-en-v1.5)
#   - Your OpenRouter API key for LLM operations
#
# LLM Configuration (uses OPENROUTER_API_KEY by default)
# MEM0_LLM_MODEL=openrouter/google/gemini-2.0-flash-001
# MEM0_LLM_API_KEY=  # Optional override; defaults to OPENROUTER_API_KEY
# MEM0_LLM_TEMPERATURE=0.1
# MEM0_LLM_MAX_TOKENS=1000
#
# Embedder Configuration (local, no API key needed)
# MEM0_EMBEDDER_MODEL=BAAI/bge-small-en-v1.5
# MEM0_EMBEDDER_DIMS=384  # Optional override for unsupported/custom models
#
# Memory Configuration
# MEM0_USER_ID=default
# MEM0_COLLECTION_NAME=agent_memories
# MEM0_SEARCH_LIMIT=5
#
# Vector Store - Embedded Mode (default)
# Memories persist on disk at this path. Directory is created automatically.
# MEM0_QDRANT_PATH=./data/qdrant
#
# Vector Store - Remote Server Mode (optional)
# Uncomment both to connect to an external Qdrant server instead of embedded mode:
# MEM0_QDRANT_HOST=localhost
# MEM0_QDRANT_PORT=6333

# ---------------------------------------------------------------------------
# OpenSandbox Integration (Optional)
# ---------------------------------------------------------------------------
# Enable isolated sandbox environments for code execution and shell commands.
# Requires opensandbox-server running locally or a remote OpenSandbox instance.
#
# Quick Start (local development):
#   1. Install: uv pip install opensandbox-server
#   2. Configure: uvx opensandbox-server init-config ~/.sandbox.toml --example docker
#   3. Edit port: ~/.sandbox.toml: port = 9090
#   4. Pre-pull image: docker pull opensandbox/code-interpreter:v1.0.2
#   5. Start server: uvx opensandbox-server
#
# Enable sandbox tools
# SANDBOX_ENABLED=true
#
# OpenSandbox server domain (default: localhost:9090)
# SANDBOX_DOMAIN=localhost:9090
#
# API key for production servers (optional for local dev)
# SANDBOX_API_KEY=
#
# Sandbox TTL in minutes (default: 30)
# SANDBOX_TIMEOUT_MINUTES=30
#
# Resource limits per sandbox
# SANDBOX_MEMORY_LIMIT=512Mi
# SANDBOX_CPU_LIMIT=0.5
#
# Docker image for sandboxes (default: opensandbox/code-interpreter:v1.0.2)
# SANDBOX_IMAGE=opensandbox/code-interpreter:v1.0.2
